# ignore everything by default.
*

!.config/
.config/*

# Neovim
!.config/nvim
.config/nvim/**
!.config/nvim/**/*

# Fish
!.config/fish
.config/fish/**
!.config/fish/config.fish

# iTerm
!.config/iterm2
.config/iterm2/**
!.config/iterm2/config
.config/iterm2/config/*
!.config/iterm2/config/*

# Skhd
!.config/skhd
.config/skhd/*
!.config/skhd/skhdrc

# Yabai
!.config/yabai
.config/yabai/*
!.config/yabai/yabairc


# Git
!.gitconfig
!.gitignore

# Tmux
!.tmux
!.tmux.conf
!.tmux/*.yml

